
def longestOnes(nums, k):
  left = 0
  right = 0
  max = 0
  flip = 0
    
  for right in range(right, len(nums)):
      if(nums[right] == 0):
        flip +=1

       while(flip > k ):
        if(nums[left] == 0):
          flip -= 1
        left += 1
    curr_max = right - left+1
    max = max(max,curr_max)
    right += 1
