def square_array(arr):
    n = len(arr)
    result_arr = [0] * n
    start = 0
    end = n - 1
    for i in range(n):
        left = arr[start] * arr[start]
        right = arr[end] * arr[end]
        
        if left > right:
            result_arr[i] = left
            start += 1
        else:
            result_arr[i] = right
            end -= 1
            
    return result_arr
